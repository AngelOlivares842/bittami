---
// src/components/TwitchPlayer.astro
interface Props {
  channel?: string;
}

const { channel = "bittami" } = Astro.props;
---

<div class="twitch-video-wrapper">
  <div id="twitch-embed"></div>
</div>

<script is:inline src="https://player.twitch.tv/js/embed/v1.js"></script>

<script is:inline define:vars={{ channel }}>
  function initTwitchPlayer() {
    if (typeof Twitch !== 'undefined' && Twitch.Player) {
      // Limpiamos el contenedor por si acaso se re-renderiza
      const container = document.getElementById("twitch-embed");
      if (container) container.innerHTML = '';

      new Twitch.Player("twitch-embed", {
        channel: channel,
        width: "100%",
        height: "100%",
        muted: false,
        autoplay: true,
        // IMPORTANTE: Tus dominios autorizados para que cargue el iframe sin errores de seguridad
        parent: ["bittami.kalwrd.me","bittami.mekode.cl", "localhost", "127.0.0.1"]
      });
    }
  }

  // Inicializa cuando la página esté lista
  window.addEventListener('load', initTwitchPlayer);
  // Por si usas transiciones de página de Astro (ViewTransitions)
  document.addEventListener('astro:page-load', initTwitchPlayer);
</script>

<style>
  .twitch-video-wrapper {
    position: relative;
    padding-bottom: 56.25%; /* Relación de aspecto 16:9 estándar */
    height: 0;
    overflow: hidden;
    max-width: 100%;
    background: #000;
    border-radius: 12px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
    border: 1px solid rgba(255, 255, 255, 0.05);
  }

  .twitch-video-wrapper :global(iframe) {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border: none;
  }
</style>