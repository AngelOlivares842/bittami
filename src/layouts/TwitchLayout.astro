---
// Layout minimalista para que nada rompa el BentoGrid
const { title } = Astro.props;
---
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <script is:inline src="https://extension-files.twitch.tv/helper/v1/twitch-ext.min.js"></script>
    <script is:inline>
    window.addEventListener('load', () => {
        console.log("BittamiHub: Intentando conectar con Twitch...");
        if (window.Twitch) {
        window.Twitch.ext.onAuthorized((auth) => {
            console.log("BittamiHub: Autorizado correctamente");
        });
        } else {
        console.error("BittamiHub: No se detectó el helper de Twitch. Revisa el script en el head.");
        }
    });
    </script>
</head>
<body class="bg-[#0a0b14] overflow-x-hidden">
    <slot />
</body>
</html>