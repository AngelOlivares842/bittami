---
// 1. IMPORTANTE: Sin esta línea, Tailwind v4 no inyecta los estilos en este layout
import '../../styles/global.css'; 

// Layout adaptado para BittamiHub en Twitch
const { title } = Astro.props;
---
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>    
    <link rel="stylesheet" href="/_astro/global.css" type="text/css">
    <meta http-equiv="Content-Security-Policy" content="frame-ancestors *;">
    <script is:inline src="/twitch-init.js"></script>

</head>
<body class="bg-[#0a0b14] text-white overflow-x-hidden selection:bg-bitta-pink/30">
    <slot />
</body>
</html>