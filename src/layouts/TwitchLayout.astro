---
// Layout minimalista para que nada rompa el BentoGrid
const { title } = Astro.props;
---
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <script src="https://extension-files.twitch.tv/helper/v1/twitch-ext.min.js"></script>
</head>
<body class="bg-[#0a0b14] overflow-x-hidden">
    <slot />
</body>
</html>